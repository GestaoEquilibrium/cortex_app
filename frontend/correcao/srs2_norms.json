{"version":"1.1","scales":{"PS":"Percepção Social","CGS":"Cognição Social","CMS":"Comunicação Social","MS":"Motivação Social","RR":"Padrões Restritivos e Repetitivos","CI":"Comunicação e Interação","TOT":"Total"},"scale_order":["PS","CGS","CMS","MS","RR","CI","TOT"],"scale_descriptions":{"PS":"Mede a capacidade de reconhecer pistas sociais e lidar com os aspectos perceptivos do comportamento social recíproco. Avalia se o indivíduo consegue identificar nuances nas interações sociais cotidianas.","CGS":"Refere-se à capacidade de interpretar as pistas sociais após reconhecê-las. Avalia o aspecto cognitivo-interpretativo do comportamento social recíproco.","CMS":"Mede a capacidade de comunicação expressiva, lidando com os aspectos motores do comportamento social recíproco. Representa os comportamentos mais 'robotizados' da comunicação.","MS":"Avalia o grau em que a pessoa é motivada a se engajar em comportamento sócio interpessoal. Inclui elementos de ansiedade social, inibição e orientação empática.","RR":"Mede comportamentos estereotipados, interesses restritos e padrões característicos de TEA, como rituais, fixações em rotinas e dificuldade com mudanças.","CI":"Composto que reúne as 4 subescalas iniciais (Percepção, Cognição, Comunicação e Motivação Social). Reflete o domínio sociocomunicativo geral.","TOT":"Escore total da escala SRS-2. Reflete a gravidade global dos comportamentos associados ao TEA, integrando todos os domínios avaliados."},"classifications":[{"label":"Típico","min":0,"max":59,"cor":"#10b981","bg":"#dcfce7","text":"#166534"},{"label":"N1","min":60,"max":65,"cor":"#f59e0b","bg":"#fef3c7","text":"#854d0e"},{"label":"N2","min":66,"max":75,"cor":"#f97316","bg":"#ffedd5","text":"#9a3412"},{"label":"N3","min":76,"max":99,"cor":"#dc2626","bg":"#fee2e2","text":"#991b1b"}],"instruments":{"SRS-2-PRE":{"form_label":"Pré-Escolar","modalidade":"hetero","norms":{"PS":{"0":28,"1":33,"2":37,"3":41,"4":44,"5":48,"6":51,"7":53,"8":55,"9":57,"10":59,"11":60,"12":62,"